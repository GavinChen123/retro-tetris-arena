{
  "name": "Retro Tetris Arena",
  "short_name": "Tetris Arena",
  "description": "An old 8-bit Tetris arena with singleplayer, CPU battles, and realtime human matches.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
